export async function getStaticPaths() {
  const endpoint =
    "https://iqemsajivxgkyvnsblsh.supabase.co/rest/v1/beer?select=*";
  const key = "sb_publishable_JJminKHUu5Xa_j_oVoNy_Q_djiIwRvF";

  const response = await fetch(endpoint, { headers: { apikey: key } });
  const products = await response.json();

  return products.map((product) => ({
    params: { slug: product.id.toString() },
    props: { product },
  }));
}
