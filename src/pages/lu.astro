---
//@ts-nocheck
import Layout from '../layouts/Layout.astro';
import Welcome from '../components/Welcome.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro'
import Countdown from '../components/Countdown.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Card from '../components/Card.astro';
import OeremaerketSection from '../components/OeremaerketSection.astro';
import Values from '../components/Values.astro';
import SocialsKarrusel from '../components/SocialsKarrusel.astro';
import MerchCountdown from '../components/MerchCountdown.astro';
import SamarbejdspartnerLandingpage from '../components/SamarbejdspartnereLandingpage.astro';
import Kortfortalt from '../components/Kortfortalt.astro';
import OmOsKortMedTekst from '../components/OmOsKortMedTekst.astro';
import DankortTilWallet from '../components/DankortTilWallet.astro';

import '../styles/effects.css';
import '../styles/global.css';
import '../styles/reset.css';
import '../styles/typography.css';
import '../styles/variables.css';


---


<Layout>
<main>
<Breadcrumbs />
  <section >

    <OmOsKortMedTekst />
  <DankortTilWallet />
    <SamarbejdspartnerLandingpage />
<Values />
<OeremaerketSection />
<MerchCountdown />
<SocialsKarrusel />

</section>
  </main>
</Layout>


<style>

  /* Grid: Mobil first (1 kolonne) */
  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Desktop version (Skærme over 768px) */
  @media (min-width: 768px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr); /* 2 kolonner på desktop, eller brug 'repeat(auto-fit, minmax(300px, 1fr))' */
    }
  }
</style>
