---
//@ts-nocheck
import Kortfortalt from '../components/Kortfortalt.astro';
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro'
import Countdown from '../components/Countdown.astro';
import OeremaerketSection from '../components/OeremaerketSection.astro';
import Values from '../components/Values.astro';
import SocialsKarrusel from '../components/SocialsKarrusel.astro';
import MerchCountdown from '../components/MerchCountdown.astro';
import SamarbejdspartnerLandingpage from '../components/SamarbejdspartnereLandingpage.astro';
---

<Layout>
    <Hero/>
	<div class="bg">
    <main>
        <!-- Tilføj overflow: hidden her for en sikkerheds skyld -->
        <article class="main_section" style="width: 100%;">
            <Kortfortalt />
            <Values />
            <OeremaerketSection />
            <SamarbejdspartnerLandingpage />
            <MerchCountdown />
            <SocialsKarrusel />
		</article>
    </main>
	
		<img id="kortFortalt-dk" src="/src/assets/mobil-rkort.svg" alt="Rødt Dankort" aria-hidden="true">
   		<img id="desk-dk" src="/src/assets/roedtkort-desktop.svg" alt="Rødt Dankort">
	</div>
</Layout>

<style>
	.main_section {
		display: flex;
		flex-direction: column;
		gap: var(--gap-xl);
		padding: 0 1rem;
	}
	.bg {
		position: relative;
		overflow: hidden;
	}
	
	#kortFortalt-dk {
		position: absolute;
		top: 100px;
		left: 280px;
		transform: rotate(43deg);
	}

	#desk-dk {
		display: none;
	}

	@media (min-width: 768px) {
		.main_section {
			display: flex;
			flex-direction: column;
			gap: var(--gap-xxl);
			padding: 0;
		}
		#kortFortalt-dk {
			display: none;
		}

		#desk-dk {
			position: absolute;
			display: inline-block;
			top: 170px;
			right: 10vw;
			transform: rotate(-36.14deg);
			width: 35vw;
		}
	}
</style>