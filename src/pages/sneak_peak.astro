        grid-template-columns: 1fr;
        gap: 2rem;
    }

.product_grid {
    display: grid ;
    grid-template-columns: 1fr;
    gap: 20px;
    width: 100% ;
  }

  .product_grid img {
    width: 100% ;
    max-width: 100% ;
    height: auto ;
    display: block ;
  }

  @media (min-width: 768px){

 .product_grid {
    display: grid ;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
    width: 100% ;
  }

  }
  
</style>