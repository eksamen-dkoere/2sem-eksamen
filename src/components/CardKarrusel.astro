---
//@ts-nocheck
import Card from './Card.astro'; // RETTET STIEN HER

import '../styles/effects.css';
import '../styles/global.css';
import '../styles/reset.css';
import '../styles/typography.css';
import '../styles/variables.css';

interface KarruselItem {
  id?: number | string;
  href: string;
  badgeText: string;
  mediaUrl: string;
  altText?: string;
  overlayText?: string;
}

interface Props {
  items: KarruselItem[];
}

const { items } = Astro.props;
---

<div class="karrusel_container">
  {items.slice(0, 3).map((item) => (
    <a class="karrusel_item" href={item.href}>
      <Card 
        badgeText={item.badgeText} 
        mediaUrl={item.mediaUrl} 
        altText={item.altText || item.badgeText}
        overlayText={item.overlayText}
        isHoverCard={true} 
      />
    </a>
  ))}
</div>

<style>
  .karrusel_container {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    padding-bottom: 1rem;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    width: 100%;
  }

  .karrusel_item {
    flex: 0 0 80%;
    max-width: 350px; 
    scroll-snap-align: start;
    text-decoration: none;
  }

  .karrusel_container::-webkit-scrollbar {
    height: 6px;
  }
  .karrusel_container::-webkit-scrollbar-thumb {
    border-radius: 4px;
  }

  @media (min-width: 768px) {
    .karrusel_container {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      overflow: visible;
    }

    .karrusel_item {
      flex: none;
      max-width: none;
    }
  }
</style>