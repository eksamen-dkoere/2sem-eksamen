---
//@ts-nocheck
import '../layouts/Layout.astro'

const { text, variant, link} = Astro.props
---
{link ? (
  <a href={link} class={`button glass ${variant}`}>
    <h5>{text}</h5>
  </a>
) : (
  <button class={`button glass ${variant}`}>
    <h5>{text}</h5>
  </button>
)}

<style>
  .button {
    padding: var(--gap-xxs) var(--gap-s);
    border: none;
    border-radius: var(--radius-l);
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
  }

  .red500, html.dark .red500 {
    background-color: rgba(247, 0, 16, 0.8);
    color: var(--white);
    border: solid 0.5px var(--white);
    transition: transform 0.3s ease, background-color 0.3s ease;
  }
  .secondary {
    color: var(--black);
    border: solid 0.5px var(--white);
    transition: transform 0.3s ease, background-color 0.3s ease;
  }
  .white-hero {
    color: var(--black);
    border: solid 0.5px var(--white);
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  .red500:hover, html.dark .red500:hover {
    background-color: rgba(153, 0, 10, 0.8);
    color: var(--white);
    border: solid 0.5px var(--white);
  }

  .secondary:hover {
    background-color: rgba(128, 225, 255, 0.5);
    color: var(--black);
    border: solid 0.5px var(--white);
    
  }

  /* darkmode */

  html.dark .secondary{
    background-color: rgba(56, 54, 46, 0.2);
    color: var(--white);
    border: solid 0.5px var(--white);
  }

  html.dark .secondary:hover{
    background-color: rgba(0, 160, 204, 0.5);
    color: var(--white);  
    border: solid 0.5px var(--white);
  }
</style>