---
//@ts-nocheck
import '../layouts/Layout.astro'

const { text, variant, link} = Astro.props
---
{link ? (
  <a href={link} class={`button glass ${variant}`}>
    <h5>{text}</h5>
  </a>
) : (
  <button class={`button glass ${variant}`}>
    <h5>{text}</h5>
  </button>
)}

<style>
  .button {
    padding: var(--gap-xxs) var(--gap-s);
    border: none;
    border-radius: var(--radius-l);
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
  }

  .red500, html.dark .red500 {
    background-color: rgba(var(--red-500-rgb), 0.8);
    color: var(--white);
    border: solid 0.5px var(--white);
    transition: transform 0.3s ease, background-color 0.3s ease;
  }
  .red500:hover, html.dark .red500:hover {
    background-color: rgba(var(--red-700-rgb), 0.8);
    color: var(--white);
    border: solid 0.5px var(--white);
  }

  .secondary {
    color: var(--black);
    border: solid 0.5px var(--white);
    transition: transform 0.3s ease, background-color 0.3s ease;
  }
  .secondary:hover {
    background-color: rgba(var(--blue-300-rgb), 0.5);
    color: var(--black);
    border: solid 0.5px var(--white);
  }
  html.dark .secondary{
    background-color: rgba(var(--neutral-800-rgb), 0.2);
    color: var(--white);
    border: solid 0.5px var(--white);
  }
  html.dark .secondary:hover{
    background-color: rgba(var(--blue-600-rgb), 0.5);
    color: var(--white);  
    border: solid 0.5px var(--white);
  }
</style>