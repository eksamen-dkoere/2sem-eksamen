---
import '../layouts/Layout.astro'
import '../components/Buttons.astro'
import Buttons from '../components/Buttons.astro'

---

<article class="hero">
  
  <video class="hero-video"
    autoplay
    muted
    loop
    playsinline
  >

     <source src="/videoes/desktop-hero.mp4" type="video/mp4" />

  </video>
    <div id="text-box-hero" class="glass">
      <h1>Støt <span id="ocr">Øremærket</span> - <br> Brug Dankort i dag</h1>
      <div id="hero-text-flex"> 
        <h4>Betal smart</h4>
        <h4>Betal hurtigt</h4>
        <h4>Betal sikkert</h4>
    </div>
   
    <div id="buttons-hero">
      <Buttons
        text="Læs om Øremærket"
        variant="red500"
        link="/om_os"/>
      <a class="mobile-cta" href="https://dankort.dk" target="_blank" rel="noopener noreferrer">
        <Buttons text="Bestil et Dankort" variant="secondary"/>
      </a>
    </div>
  </div>
</article>

<style>
  #buttons-hero{
    display: flex;
    flex-direction: row;
    gap: var(--gap-xs);
  }

  #text-box-hero {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    color: white;
    display: flex;
    flex-direction: column;
    gap: var(--gap-xl);
    width: 95vw;
    padding: var(--gap-s);
    border-radius: var(--radius-xl);
  }

  .hero {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
  }

  .hero video {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    transform: translate(-50%, -50%);
    object-fit: cover;
    z-index: -1;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
  }

  #hero-text-flex{
    display: flex;
    gap: var(--gap-m);
    flex-direction: column;
    align-items: flex-start;
  }

  span#ocr {
    font-family: "ocr-a-std", monospace, sans-serif;
  }

  @media (min-width: 769px) {
  #buttons-hero{
      gap: var(--gap-l);
  }
  #hero-text-flex{
      display: flex;
      flex-direction: row;
      align-items: flex-start;
  }
    #text-box-hero {
      left: 39%;
      display: inline-flex;
      flex-direction: column;
      align-items: flex-start;
      width: 770px;
      gap: var(--gap-xl);
    }
  }
  /* HUSK AT TILFØJE EN KNAP MERE */
</style>