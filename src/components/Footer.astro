---
//@ts-nocheck
import '../layouts/Layout.astro';
import '../styles/effects.css';
import '../styles/global.css';
import '../styles/reset.css';
import '../styles/typography.css';
import '../styles/variables.css';

import tiktokSort from '../assets/tiktok-sort-logo.svg';
import tiktokHvid from '../assets/tiktok-logo.svg';
import instagramSort from '../assets/instagram-sort-logo.svg';
import instagramHvid from '../assets/instagram-logo.svg';
import facebookSort from '../assets/facebook-sort-logo.svg';
import facebookHvid from '../assets/facebook-logo.svg';
// import dkLogo from '../assets/'
---

<footer class="site-footer">
  <div class="magnetic-strip"></div>

  <div class="footer-content">
    <div class="footer-brand">
      <div class="brand-logo-text special_text">Dankort Øremærket</div>
    </div>

    <div class="footer-nav">
      
      <div class="footer-section">
        <button class="accordion-trigger" aria-expanded="false">
          Dankort Øremærket <span class="icon">+</span>
        </button>
        <div class="accordion-content">
          <ul class="footer-links">
            <li><a href="/">Forside</a></li>
            <li><a href="/find">Find dit kort</a></li>
            <li><a href="/sneak-peak">Sneak peak</a></li>
            <li><a href="/om-os">Om os</a></li>
          </ul>
        </div>
      </div>

      <div class="footer-section">
        <button class="accordion-trigger" aria-expanded="false">
          Kontakt Dankort <span class="icon">+</span>
        </button>
        <div class="accordion-content contact-info">
          <p>Telefon åben: 08:00 - 15:00</p>
          <p><a href="tel:+4512345678">+45 12 34 56 78</a></p>
          <p><a href="mailto:dankort@øremærket.dk">dankort@øremærket.dk</a></p>
        </div>
      </div>

      <div class="footer-section">
        <button class="accordion-trigger" aria-expanded="false">
          Dankort <span class="icon">+</span>
        </button>
        <div class="accordion-content">
          <ul class="footer-links">
            <li><a href="/om">Om Dankort</a></li>
            <li><a href="/privatliv">Privatlivspolitikker</a></li>
            <li><a href="/cookies">Cookies</a></li>
          </ul>
        </div>
      </div>

    </div>

    <div class="footer-bottom">
      <div class="social-links">
  <a href="https://tiktok.com" aria-label="TikTok" class="social-icon">
    <img src={tiktokSort.src} class="icon-light" alt="TikTok" />
    <img src={tiktokHvid.src} class="icon-dark" alt="TikTok" />
  </a>
  <a href="https://instagram.com" aria-label="Instagram" class="social-icon">
    <img src={instagramSort.src} class="icon-light" alt="Instagram" />
    <img src={instagramHvid.src} class="icon-dark" alt="Instagram" />
  </a>
  <a href="https://facebook.com" aria-label="Facebook" class="social-icon">
    <img src={facebookSort.src} class="icon-light" alt="Facebook" />
    <img src={facebookHvid.src} class="icon-dark" alt="Facebook" />
  </a>
</div>
      
      <div class="dk-logo">
        <img src="/Logo.svg" alt="Dankort Logo" />
      </div>

    </div>
  </div>
</footer>

<script>
  const sections = document.querySelectorAll('.footer-section');

  function handleAccordion() {
    const isMobile = window.innerWidth <= 768;
    sections.forEach(section => {
      const trigger = section.querySelector('.accordion-trigger');
      if (!trigger) return; 
      
      const icon = trigger.querySelector('.icon');
      
      if (isMobile) {
        trigger.setAttribute('aria-expanded', 'false');
        if (icon) icon.textContent = '+';
      } else {
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  }

  sections.forEach(section => {
    const trigger = section.querySelector('.accordion-trigger');
    if (!trigger) return;

    trigger.addEventListener('click', () => {
      if (window.innerWidth <= 768) {
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        
        document.querySelectorAll('.accordion-trigger').forEach(btn => {
          btn.setAttribute('aria-expanded', 'false');
          const icon = btn.querySelector('.icon');
          if (icon) icon.textContent = '+';
        });

        trigger.setAttribute('aria-expanded', String(!isExpanded));
        const icon = trigger.querySelector('.icon');
        if (icon) icon.textContent = !isExpanded ? '—' : '+';
      }
    });
  });

  handleAccordion();
  window.addEventListener('resize', handleAccordion);
</script>

<style>
.site-footer {
    color-scheme: light dark;
    width: 100%;
    background-color: var(--neutral-200);
    color: var(--black);
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;
    padding: 0;
    box-sizing: border-box;
    overflow: hidden;
    display: block;
  }

  html.dark .site-footer {
    background: var(--neutral-800);
    color: var(--white);
  }

.magnetic-strip {
    width: 100%;
    height: 3rem;
    background-color: var(--black);
    margin-top: 3rem; 
    margin-bottom: 1rem; 
    display: block;
  }

  .footer-content {
    padding: 0 1.5rem 1.5rem 1.5rem;
  }

  .footer-brand {
    margin-bottom: 1.5rem;
  }
  
  .brand-logo-text {
    background: var(--white);
    color: var(--black);
    display: inline-block;
    padding: 0.5rem 5rem;
    font-size: 1.2rem;
    min-width: 220px;
    box-sizing: border-box;
    text-align: center;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .footer-section {
    display: flex;
    flex-direction: row; 
    align-items: flex-start;
    justify-content: space-between;
    width: 100%;
    min-height: 35px;
  }

  .accordion-trigger {
    background: none;
    border: none;
    color: inherit;
    font-weight: bold;
    font-size: 1.1rem;
    text-align: left;
    padding: 0;
    margin: 0;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 45%; 
    flex-shrink: 0;
    font-family: inherit;
  }

  .accordion-trigger .icon {
    margin-left: auto;
    padding-right: 1rem;
  }

  .accordion-content {
    display: none; 
    width: 55%; 
    padding-left: 0.5rem;
    box-sizing: border-box;
  }

  .accordion-trigger[aria-expanded="true"] + .accordion-content {
    display: block;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-links a, .contact-info p, .contact-info a {
    color: inherit;
    text-decoration: none;
    font-weight: normal;
    margin: 0;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1.5rem;
  }

  .social-links {
    display: flex;
    gap: 1.25rem;
  }

  .social-icon {
    width: 28px;
    height: 28px;
    display: inline-block;
  }

  .social-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* HTML-baseret Light/dark skift */
  .icon-dark { display: none; }
  .icon-light { display: block; }

  @media (prefers-color-scheme: dark) {
    .icon-light { display: none; }
    .icon-dark { display: block; }
  }

  .dk-logo img {
    height: 35px;
    width: auto;
  }

  /* ==========================================
     2. DESKTOP STYLES (Fra 768px og op)
     ========================================== */
  @media (min-width: 768px) {
    .footer-content {
      padding: 0 4rem 3rem 4rem;
    }

    :global(.magnetic-strip) {
      margin-bottom: 3.5rem;
    }

    .brand-logo-text {
      min-width: 450px; 
    }

    .footer-nav {
      flex-direction: row;
      justify-content: flex-start;
      align-items: flex-start; 
      gap: 4rem;
      margin-bottom: 4rem;
      max-width: 800px;
    }

    .footer-section {
      flex-direction: column; 
      width: auto; 
      min-height: auto;
    }

    .accordion-trigger {
      width: auto;
      cursor: default;
      font-size: 1rem;
      margin-bottom: 1rem;
    }

    .accordion-trigger .icon {
      display: none; 
    }

    .accordion-content {
      display: block !important; 
      width: auto;
      padding-left: 0;
    }
  }
</style>