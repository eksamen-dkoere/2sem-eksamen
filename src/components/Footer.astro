    <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 25 25" fill="none">
      <path class="svg-dark" fill-rule="evenodd" clip-rule="evenodd" d="M0 5C0 2.23857 2.23857 0 5 0H20C22.7614 0 25 2.23857 25 5V20C25 22.7614 22.7614 25 20 25H5C2.23857 25 0 22.7614 0 20V5ZM5 2.5C3.61929 2.5 2.5 3.61929 2.5 5V20C2.5 21.3807 3.61929 22.5 5 22.5H20C21.3807 22.5 22.5 21.3807 22.5 20V5C22.5 3.61929 21.3807 2.5 20 2.5H5ZM12.5 8.75C10.4289 8.75 8.75 10.4289 8.75 12.5C8.75 14.5711 10.4289 16.25 12.5 16.25C14.5711 16.25 16.25 14.5711 16.25 12.5C16.25 10.4289 14.5711 8.75 12.5 8.75ZM6.25 12.5C6.25 9.04822 9.04822 6.25 12.5 6.25C15.9517 6.25 18.75 9.04822 18.75 12.5C18.75 15.9517 15.9517 18.75 12.5 18.75C9.04822 18.75 6.25 15.9517 6.25 12.5ZM19.375 7.5C20.4105 7.5 21.25 6.66054 21.25 5.625C21.25 4.58946 20.4105 3.75 19.375 3.75C18.3395 3.75 17.5 4.58946 17.5 5.625C17.5 6.66054 18.3395 7.5 19.375 7.5Z" fill="var(--black)"/>
