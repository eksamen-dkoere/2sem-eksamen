        </button>
        <div class="accordion-content">
          <ul class="footer-links">
            <li><a href="/om">Om Dankort</a></li>
            <li><a href="/privatliv">Privatlivspolitikker</a></li>
            <li><a href="/cookies">Cookies</a></li>
