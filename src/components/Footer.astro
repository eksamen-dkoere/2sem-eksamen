</div>
      
      <div class="logo">
        <a href="/">
            <Logo/>
        </a>
      </div>

    </div>
  </div>
</footer>

<script>
  const sections = document.querySelectorAll('.footer-section');

  function handleAccordion() {
    const isMobile = window.innerWidth <= 768;
    sections.forEach(section => {
      const trigger = section.querySelector('.accordion-trigger');
      if (!trigger) return; 
      
      const icon = trigger.querySelector('.icon');
      
      if (isMobile) {
        trigger.setAttribute('aria-expanded', 'false');
        if (icon) icon.textContent = '+';
      } else {
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  }

  sections.forEach(section => {
    const trigger = section.querySelector('.accordion-trigger');
    if (!trigger) return;

    trigger.addEventListener('click', () => {
      if (window.innerWidth <= 768) {
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        
        document.querySelectorAll('.accordion-trigger').forEach(btn => {
          btn.setAttribute('aria-expanded', 'false');
          const icon = btn.querySelector('.icon');
          if (icon) icon.textContent = '+';
        });

        trigger.setAttribute('aria-expanded', String(!isExpanded));
        const icon = trigger.querySelector('.icon');
        if (icon) icon.textContent = !isExpanded ? '—' : '+';
      }
    });
  });

  handleAccordion();
  window.addEventListener('resize', handleAccordion);
</script>

<style>
  footer {
    margin-top: var(--gap-xl);
  }
.site-footer {
    color-scheme: light dark;
    width: 100%;
    background-color: var(--neutral-200);
    color: var(--black);
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;
    padding: 0;
    box-sizing: border-box;
    overflow: hidden;
    display: block;
    box-shadow: var(--innershadow-light), var(--dropshadow);
  }

  html.dark .site-footer {
    background: var(--neutral-800);
    color: var(--white);
  }

.magnetic-strip {
    width: 100%;
    height: 40px;
    background-color: var(--black);
    margin-top: 40px; 
    margin-bottom: 1rem; 
    display: block;
  }

  .footer-content {
    padding: 0 1.5rem 1.5rem 1.5rem;
  }

  .footer-brand {
    margin-bottom: var(--gap-xxs);
  }
  
  .brand-logo-text {
    background: var(--white);
    color: var(--black);
    display: inline-block;
    min-width: 220px;
    padding: 2px 0;
    box-sizing: border-box;
    text-align: center;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
  }

  .footer-section {
    display: flex;
    flex-direction: row; 
    align-items: flex-start;
    justify-content: space-between;
    width: 100%;
    min-height: 35px;
  }

  .accordion-trigger {
    background: none;
    border: none;
    color: inherit;
    font-weight: bold;
    text-align: left;
    padding: 0;
    margin: 0;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 50%; 
    flex-shrink: 0;
    font-family: inherit;
  }

  .accordion-trigger .icon {
    margin-left: auto;
    padding-right: 1rem;
  }

  .accordion-content {
    display: none; 
    width: 55%; 
    padding-left: 0.5rem;
    box-sizing: border-box;
  }

  .accordion-content p {
    font-size: 14px;
    padding-bottom: 0.4rem;
  }

  .accordion-trigger[aria-expanded="true"] + .accordion-content {
    display: block;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-links a, .contact-info p, .contact-info a {
    color: inherit;
    text-decoration: none;
    font-weight: normal;
    margin: 0;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .social-links {
    display: flex;
    gap: 1.25rem;
  }

  .social-icon {
    width: 28px;
    height: 28px;
    display: inline-block;
  }

  .social-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .logo {
        width: 50px;
        object-fit: cover;
    }

  /* HTML-baseret Light/dark skift */
  html.dark .svg-dark {
    fill: var(--white);
  }
  .svg-dark-tiktok {
    color: var(--black);
  }
  html.dark .svg-dark-tiktok {
    color: var(--white);
  }

  @media (prefers-color-scheme: dark) {
    .icon-light { display: none; }
    .icon-dark { display: block; }
  }


  /* ==========================================
     2. DESKTOP STYLES (Fra 768px og op)
     ========================================== */
  @media (min-width: 768px) {
    footer {
    margin-top: var(--gap-xxl);
  }
    .site-footer {
      border-top-left-radius: 50px;
      border-top-right-radius: 50px;
      /* height: 500px; */
    }

    .footer-content {
      max-width: 1200px;
      margin: 0 auto;
    }

    :global(.magnetic-strip) {
      margin-bottom: 3.5rem;
    }

    .magnetic-strip{
      height: 80px;
      margin-top: 80px; 
      margin-bottom: var(--gap-m);
    }

    .brand-logo-text {
      min-width: 450px; 
      width: 50%;
      padding: 0;
    }

    .footer-nav {
      flex-direction: row;
      justify-content: flex-start;
      align-items: flex-start; 
      gap: 4rem;
      max-width: 800px;
    }

    .footer-section {
      flex-direction: column; 
      width: auto; 
      min-height: auto;
    }

    .accordion-trigger {
      width: auto;
      cursor: default;
      font-size: 1rem;
      margin-bottom: 1rem;
    }

    .accordion-trigger .icon {
      display: none; 
    }

    .accordion-content {
      display: block !important; 
      width: auto;
      padding-left: 0;
    }
    .social-links {
      gap: var(--gap-l);
    }
    .logo {
        width: 100px;
    }
  }
</style>