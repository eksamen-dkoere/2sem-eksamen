---
//@ts-nocheck
const { title, content, variant } = Astro.props;
---

<details class={`accordion ${variant}`}>
    <summary>
        <h3>{title}</h3>
        <span class="accordion-icon"></span>
    </summary>
    <div class="accordion-content">
        <p>{content}</p>
    </div>
</details>

<style>
    .accordion { 
        border-top: 1px solid var(--neutral-300);
        padding: 1rem 0;
    }

    summary { 
        cursor: pointer;
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .accordion-icon::before {
        content: "+";
    }

    details[open] .accordion-icon::before {
        content: "-";
    }

    .accordion-content {
        margin-top: 1rem;
    }

    /* ---- FARVER FOR LIGHTMODE VARIANT (Vises i Dark Mode html.dark) ---- */
    .lightmode { 
        border-color: var(--neutral-300);
        color: var(--white); 
    }

    /* ---- FARVER FOR DARKMODE VARIANT (Vises i Light Mode) ---- */
    .darkmode { 
        border-color: var(--neutral-800);
        color: var(--black); 
    }

 /* ==========================================================================
       LOGIK: SKJUL/VIS BASERET PÅ DARK MODE (Rettet med :global)
       ========================================================================== */

    /* Når siden er i Light Mode (html har IKKE .dark) -> Skjul variant="lightmode" */
    :global(html:not(.dark)) .lightmode {
        display: none !important;
    }

    /* Når siden er i Dark Mode (html HAR .dark) -> Skjul variant="darkmode" */
    :global(html.dark) .darkmode {
        display: none !important;
    }
</style>