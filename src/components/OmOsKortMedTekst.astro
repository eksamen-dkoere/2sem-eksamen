---
//@ts-nocheck
import omOsKort from '../assets/om-os-kort.svg';
---

<!-- 2. Brug den importerede URL direkte i en inline style på din container -->
<div class="card-container" style={`background-image: url(${omOsKort.src});`}>
  <ol class="card-text-list">
    <li>Hver gang du bruger <span class="highlight">Dankort</span>, donerer vi 1 øre pr. transaktion.</li>
    <li>Er din <span class="highlight">bank</span> en samarbejdspartner donerer de 1 øre pr. transaktion.</li>
    <li>Hvis du handler i en <span class="highlight">butik/webshop</span> der er samarbejdspartner donerer de 1 øre pr. transaktion.</li>
  </ol>
</div>

<style>
/* Fjern 'background-image' herfra, da den nu styres oppe i HTML'en */
.card-container {
  position: relative;
  width: 100%;
  max-width: 650px;
  aspect-ratio: 1.58 / 1;
  margin: 2rem auto;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 3rem;
  box-sizing: border-box;
  border-radius: 1.5rem;
 
}

.card-text-list {
  color: var(--white)!important;
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin: 0;
  padding: 0;
  z-index: 10;
}

.card-text-list li {
  font-size: 1.15rem;
  line-height: 1.6;
}

.highlight {
  font-weight: 800;
  color: var(--white);
}
</style>