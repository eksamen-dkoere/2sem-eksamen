<style>
    .overordnet_grid {
        display: flex;
        flex-direction: column;
        gap: var(--gap-s);
        align-items: center;
        overflow: hidden;
    }

    .text_part {
        display: flex;
        flex-direction: column;
        gap: var(--gap-xs);
    }
    
   .illustrations {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        align-items: center;
        /* DETTE CENTRERER ELEMENTERNE HORISONTALT I HVER GRID-KOLONNE */
        justify-items: center; 
        max-width: 700px;
        width: 100%;
    }

    .smaller {
        width: 1rem; /* Brug width i stedet for max-width for at låse størrelsen */
        height: auto;
    }

    .coin {
        width: 3rem;
        height: auto;
    }

    .tree {
        width: 100%;
        height: auto;
    }

    html.dark .svg-dark {
        fill: var(--white);
    }

    /* Sørg for at SVG'erne fylder deres kasser ud */
    .illustrations svg {
        width: 100%;
        height: auto;
        display: block;
    }

    @media (min-width: 768px) {
        .coin {
            width: 4rem;
            height: auto;
        }
        .smaller {
            width: 1.5rem;
        }
    }
</style>