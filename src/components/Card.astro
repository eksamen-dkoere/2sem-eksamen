---
import '../styles/effects.css';
import '../styles/global.css';
import '../styles/reset.css';
import '../styles/typography.css';
import '../styles/variables.css';

interface Props {
  badgeText: string;
  mediaUrl?: string;
  altText?: string;
  inlineSvg?: string;
  overlayText?: string;
  isHoverCard?: boolean;
}

const { badgeText, mediaUrl, altText = "Kort", inlineSvg, overlayText, isHoverCard = false } = Astro.props;
---

<div class={`card glass ${isHoverCard ? 'has-hover' : ''}`}>
  <div class="card-badge">
    <h4>{badgeText}</h4>
  </div>

  <div class="card-content">
    {inlineSvg ? (
    <div class="svg-wrapper" set:html={inlineSvg} title={altText} />
    ) : (
      <img src={mediaUrl} alt={altText} loading="lazy" />
    )}
      <div class="card-overlay-text">
        {overlayText}
      </div>
  </div>
</div>

<style>
/* Variabler – light mode */
:global(:root) {
  --badge-bg: var(--white);
  --badge-text: var(--black);
}

/* Variabler – dark mode */
:global(html.dark),
:global(body.dark) {
  --badge-bg: var(--black);
  --badge-text: var(--white);
}

/* Selve kortet */
.card {
  position: relative;
  width: 100%;
  aspect-ratio: 3/4;
  border-radius: 0 16px 16px 16px;
  overflow: hidden;
  background: var(--badge-bg);
  transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.4s ease;
}

/* Badge */
.card-badge {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 10;
  background-color: var(--badge-bg);
  color: var(--badge-text);
  padding: 16px 24px;
  border-bottom-right-radius: 16px;
}

/* Badge buer */
.card-badge::after,
.card-badge::before {
  content: "";
  position: absolute;
  z-index: -1;
  background: transparent;
  border-top-left-radius: 16px;
  box-shadow: -4px -4px 0 4px var(--badge-bg);
}

.card-badge::after {
  right: -16px;
  top: 0;
  width: 16px;
  height: 16px;
}

.card-badge::before {
  left: 0;
  bottom: -16px;
  width: 16px;
  height: 16px;
}

/* Indhold */
.card-content {
  position: absolute;
  inset: 0;
  z-index: 5;
}

/* Billeder */
.card-content img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Inline SVG wrapper */
.svg-wrapper {
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: inherit;
}

.svg-wrapper :global(svg) {
  width: 70%;
  height: 100%;
  display: block;
  margin: 0 auto;
}

/* Overlay tekst nederst til venstre (IKKE FELD LÆNGERE) */
.card-overlay-text {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 20;
  color: var(--white);
  font-size: 1rem;
  font-weight: normal; /* RETTET: Ikke længere bold */
  text-align: left; /* Tvinger teksten til venstre uanset forældre-elementer */
  padding: 40px 20px 20px 20px;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.4) 60%, transparent 100%);
  
  opacity: 1; 
  transition: opacity 0.4s ease, transform 0.4s ease;
}

/* --- HOVER EFFEKT --- */
.card.has-hover {
  transform: scale(0.93);
}

.card.has-hover .card-overlay-text {
  opacity: 0;
  transform: translateY(10px);
  pointer-events: none;
}

:global(.karrusel_item:hover) .card.has-hover {
  transform: scale(1.03);
  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.25);
}

:global(.karrusel_item:hover) .card.has-hover .card-overlay-text {
  opacity: 1;
  transform: translateY(0);
}
</style>