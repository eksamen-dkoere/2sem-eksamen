---
import '../styles/effects.css';
import '../styles/global.css';
import '../styles/reset.css';
import '../styles/typography.css';
import '../styles/variables.css';
interface Props {
  badgeText: string;
  mediaUrl?: string;
  altText?: string;
  inlineSvg?: string;
  overlayText?: string;
}

const { badgeText, mediaUrl, altText = "Kort", inlineSvg, overlayText } = Astro.props;
---

<div class="card glass">
  <!-- Badge -->
  <div class="card-badge">
    {badgeText}
  </div>

  <!-- Indhold -->
  <div class="card-content">
    {inlineSvg ? (
      <div class="svg-wrapper" set:html={inlineSvg} title={altText} />
    ) : (
      <img src={mediaUrl} alt={altText} loading="lazy" />
    )}

    <!-- Overlay tekst nederst centreret -->
    <div class="card-overlay-text">
      {overlayText}
    </div>
  </div>
</div>

<style>
/* Variabler – light mode */
:global(:root) {
  --badge-bg: #fdfaf0;
  --badge-text: #000;
}

/* Variabler – dark mode */
:global(html.dark),
:global(body.dark) {
  --badge-bg: #000;
  --badge-text: #fff;
}

/* Selve kortet */
.card {
  position: relative;
  width: 100%;
  aspect-ratio: 3 / 4;
  border-radius: 0 16px 16px 16px;
  overflow: hidden;
  background: var(--badge-bg);
}

/* Badge */
.card-badge {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 10;
  background-color: var(--badge-bg);
  color: var(--badge-text);
  padding: 16px 24px;
  font-weight: bold;
  font-family: sans-serif;
  font-size: 20px;
  border-bottom-right-radius: 16px;
}

/* Badge buer */
.card-badge::after,
.card-badge::before {
  content: "";
  position: absolute;
  z-index: -1;
  background: transparent;
  border-top-left-radius: 16px;
  box-shadow: -4px -4px 0 4px var(--badge-bg);
}

.card-badge::after {
  right: -16px;
  top: 0;
  width: 16px;
  height: 16px;
}

.card-badge::before {
  left: 0;
  bottom: -16px;
  width: 16px;
  height: 16px;
}

/* Indhold */
.card-content {
  position: absolute;
  inset: 0;
  z-index: 5;
}

/* Billeder */
.card-content img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Inline SVG wrapper */
.svg-wrapper {
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: inherit;
}

.svg-wrapper :global(svg) {
  width: 100%;
  height: 100%;
  display: block;
}

/* Overlay tekst nederst centreret */
.card-overlay-text {
  position: absolute;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  color: white;
  font-size: 24px;
  font-weight: bold;
  text-shadow: 0 2px 6px rgba(0,0,0,0.4);
  pointer-events: none;
  text-align: center;
  width: 90%;
}
</style>