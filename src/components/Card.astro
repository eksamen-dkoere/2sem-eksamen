

---
// src/components/Card.astro
interface Props {
  badgeText: string;
  mediaUrl: string;
  altText?: string;
}

const { badgeText, mediaUrl, altText = "Kort indhold" } = Astro.props;

// Find ud af hvilken type fil der er tale om ud fra filendelsen
const isVideo = /\.(mp4|webm|webp|svg|ogg)$/i.test(mediaUrl);
const isPDF = /\.(pdf)$/i.test(mediaUrl);
---

<div class="glass">
  <div class="glass-badge">{badgeText}</div>
  <div class="glass-content">
    {isVideo && (
      <video src={mediaUrl} autoplay loop muted playsinline></video>
    )}
    
    {isPDF && (
      <iframe src={mediaUrl} title={altText}></iframe>
    )}
    
    {!isVideo && !isPDF && (
      <img src={mediaUrl} alt={altText} loading="lazy" />
    )}
  </div>
</div>

<style>
  .glass {
    position: relative; 
    width: 100%;        
    height: 100%;      
    border-radius: 0px 16px 16px 16px; 
    overflow: visible; 
  }

  .glass-badge {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 10; 
    
    background-color: #ffffff; 
    color: #000000; 
    padding: 16px 24px;
    font-weight: bold;
    font-family: sans-serif;
    font-size: 20px;
    
    border-top-left-radius: 0px; 
    border-bottom-right-radius: 16px; 
  }

  .glass-badge::after {
    content: "";
    position: absolute;
    right: -16px; 
    top: 0;
    width: 16px;   
    height: 16px;  
    background: transparent;
    border-top-left-radius: 16px;
    box-shadow: -4px -4px 0 4px #ffffff; 
    pointer-events: none;
  }

  .glass-badge::before {
    content: "";
    position: absolute;
    left: 0;
    bottom: -16px; 
    width: 16px;   
    height: 16px;  
    background: transparent;
    border-top-left-radius: 16px;
    box-shadow: -4px -4px 0 4px #ffffff; 
    pointer-events: none;
  }

  .glass-content {
    width: 100%;
    height: 100%;
  }

  .glass-content img,
  .glass-content video,
  .glass-content iframe {
    width: 100%;
    height: 100%;
    object-fit: cover; 
    display: block;
    border: none;
    border-radius: 0px 16px 16px 16px; 
  }
</style>